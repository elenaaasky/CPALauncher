                                                       ToolTip="{Binding ProbeUrlToolTip}"
                                                       Style="{StaticResource ConfigTileTitleStyle}"
                                                       Margin="0,4,10,0"/>
                                            <TextBlock Text="{Binding ManagementUrlDisplay, StringFormat=管理页 {0}}"
                                                       ToolTip="{Binding ManagementUrlToolTip}"
                                                       Style="{StaticResource ConfigTileValueStyle}"
                                                       FontSize="12"
                                                       Margin="0,3,10,0"/>
