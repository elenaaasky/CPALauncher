                                                    <Setter Property="Text" Value="隐藏"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsConfigurationInfoHidden}" Value="True">
                                                            <Setter Property="Text" Value="显示"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
