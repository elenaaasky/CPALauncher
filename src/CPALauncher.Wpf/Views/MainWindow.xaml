                                        <TextBlock Text="清空"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <Border BorderBrush="{DynamicResource LineBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="0,4,0,0">
                            <ListBox x:Name="DiagnosticListBox"
                                     ItemsSource="{Binding DiagnosticLines}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Visible"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling"
                                     VirtualizingPanel.ScrollUnit="Pixel">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="2,4"/>
                                        <Setter Property="Focusable" Value="False"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1">
                                                        <ContentPresenter Margin="{TemplateBinding Padding}"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   FontFamily="Cascadia Mono, Consolas"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource MutedBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </DockPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="2" Margin="34,0,34,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8"
                             Height="8"
                             Fill="{Binding StatusForegroundBrush}"
                             Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding FooterStatusText}"
                               FontSize="13"
                               Foreground="{DynamicResource MutedBrush}"/>
                </StackPanel>
            </Grid>

            <Border HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,76,34,0"
                    Padding="16,12"
                    CornerRadius="10"
                    Background="{DynamicResource OverlayPanelBrush}"
                    BorderBrush="{DynamicResource LineBrush}"
                    BorderThickness="1"
                    Opacity="0.98"
                    Panel.ZIndex="20"
                    IsHitTestVisible="False"
                    Visibility="{Binding IsImportNoticeVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.18"/>
                </Border.Effect>
                <TextBlock Text="{Binding ImportNoticeText}"
                           FontSize="13"
                           Foreground="{DynamicResource InkBrush}"
                           TextWrapping="Wrap"
                           MaxWidth="320"/>
            </Border>

            <StackPanel x:Name="MainGrowlPanel"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Width="360"
                        Margin="0,76,34,0"
                        Panel.ZIndex="25"/>

            <Grid Grid.RowSpan="3"
                  Panel.ZIndex="15"
                  Background="{DynamicResource DropOverlayScrimBrush}"
                  IsHitTestVisible="False"
                  Visibility="{Binding IsTokenDropOverlayVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="520"
                        Padding="28,24"
                        CornerRadius="16"
                        Background="{DynamicResource OverlayPanelBrush}"
                        BorderThickness="2"
                        BorderBrush="{Binding TokenDropAccentBrush}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.28"/>
                    </Border.Effect>
                    <StackPanel HorizontalAlignment="Center">
                        <Border Width="58"
                                Height="58"
                                CornerRadius="29"
                                Background="{Binding TokenDropAccentBrush}"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,14">
                            <TextBlock Text="&#xE8B5;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="25"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding TokenDropTitle}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource InkBrush}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding TokenDropSubtitle}"
                                   FontSize="13"
                                   Foreground="{DynamicResource MutedBrush}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="420"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</hc:Window>
