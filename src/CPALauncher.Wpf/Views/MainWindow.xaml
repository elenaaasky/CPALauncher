<hc:Window x:Class="CPALauncher.Views.MainWindow"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:hc="https://handyorg.github.io/handycontrol"
           xmlns:vm="clr-namespace:CPALauncher.ViewModels"
           Title="CPA Launcher"
           Width="1100" Height="860"
           MinWidth="960" MinHeight="720"
           WindowStartupLocation="CenterScreen"
           UseLayoutRounding="True"
           SnapsToDevicePixels="True"
           Background="{DynamicResource RegionBrush}">

    <hc:Window.DataContext>
        <vm:MainViewModel/>
    </hc:Window.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="28,24,28,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="180"/>
            </Grid.RowDefinitions>

            <!-- ============ Row 0: Header ============ -->
            <DockPanel Grid.Row="0" Margin="0,0,0,20">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            VerticalAlignment="Top" Margin="0,6,0,0">
                    <TextBlock Text="深色模式" FontSize="12"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ToggleButton Style="{StaticResource ToggleButtonSwitch}"
                                  IsChecked="{Binding IsDarkMode}"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="CPA Launcher"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock Text="管理 CLIProxyAPI 的启动、停止与托盘化。"
                               FontSize="12" Margin="0,4,0,0"
                               Foreground="{DynamicResource ThirdlyTextBrush}"/>
                </StackPanel>
            </DockPanel>

            <!-- ============ Row 1: Status + Actions ============ -->
            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Status Card -->
                <Border Grid.Column="0"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        CornerRadius="8" Padding="20">
                    <StackPanel>
                        <TextBlock Text="当前状态" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,0,0,12"/>
                        <Border Background="{Binding StatusBackgroundBrush}"
                                CornerRadius="6" Padding="0,14" Margin="0,0,0,14">
                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="{Binding StatusForegroundBrush}"
                                       FontSize="20" FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding StatusDetail}"
                                   FontSize="12" TextWrapping="Wrap"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="PID：" FontSize="12"
                                       Foreground="{DynamicResource ThirdlyTextBrush}"/>
                            <TextBlock Text="{Binding ManagedProcessId}" FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding UpdateStatusText}" FontSize="11"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   TextWrapping="Wrap" Margin="0,8,0,0"
                                   Visibility="{Binding UpdateStatusVisibility}"/>
                        <ProgressBar Value="{Binding UpdateProgress}" Maximum="100" Height="6"
                                     Margin="0,6,0,0"
                                     Visibility="{Binding UpdateProgressVisibility}"/>
                    </StackPanel>
                </Border>

                <!-- Actions Card -->
                <Border Grid.Column="2"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        CornerRadius="8" Padding="20">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="快捷操作" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,0,0,12"/>
                        <UniformGrid Rows="2" Columns="3">
                            <Button Content="启动 CPA" Command="{Binding StartCommand}"
                                    Style="{StaticResource ButtonPrimary}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,0,6,8" Height="46" FontSize="13"/>
                            <Button Content="停止 CPA" Command="{Binding StopCommand}"
                                    HorizontalAlignment="Stretch"
                                    Margin="3,0,3,8" Height="46" FontSize="13"/>
                            <Button Content="打开管理页" Command="{Binding OpenManagementCommand}"
                                    HorizontalAlignment="Stretch"
                                    Margin="6,0,0,8" Height="46" FontSize="13"/>
                            <Button Content="打开日志目录" Command="{Binding OpenLogsCommand}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,0,6,0" Height="46" FontSize="13"/>
                            <Button Content="重新检测" Command="{Binding RefreshCommand}"
                                    HorizontalAlignment="Stretch"
                                    Margin="3,0,3,0" Height="46" FontSize="13"/>
                            <Button Content="检查更新" Command="{Binding CheckForUpdateCommand}"
                                    HorizontalAlignment="Stretch"
                                    Margin="6,0,0,0" Height="46" FontSize="13"/>
                        </UniformGrid>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- ============ Row 2: Paths ============ -->
            <Border Grid.Row="2" Background="{DynamicResource SecondaryRegionBrush}"
                    CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="可执行文件"
                               FontSize="12" VerticalAlignment="Center"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Text="{Binding ExecutablePath, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="True" FontSize="12" Margin="0,0,8,0"/>
                    <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal">
                        <Button Content="浏览" Command="{Binding BrowseExecutableCommand}"
                                Width="64" Margin="0,0,6,0"/>
                        <Button Content="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                Command="{Binding OpenExecutableDirCommand}"
                                Width="36" ToolTip="打开所在目录"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="配置文件"
                               FontSize="12" VerticalAlignment="Center"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox Grid.Row="2" Grid.Column="1"
                             Text="{Binding ConfigPath, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="True" FontSize="12" Margin="0,0,8,0"/>
                    <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal">
                        <Button Content="浏览" Command="{Binding BrowseConfigCommand}"
                                Width="64" Margin="0,0,6,0"/>
                        <Button Content="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                Command="{Binding OpenConfigDirCommand}"
                                Width="36" ToolTip="打开所在目录"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============ Row 3: Info + Options ============ -->
            <Grid Grid.Row="3" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Info -->
                <Border Grid.Column="0" Background="{DynamicResource SecondaryRegionBrush}"
                        CornerRadius="8" Padding="20">
                    <StackPanel>
                        <TextBlock Text="推断信息" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="22"/>
                                <RowDefinition Height="22"/>
                                <RowDefinition Height="22"/>
                                <RowDefinition Height="22"/>
                                <RowDefinition Height="22"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="管理页 URL" FontSize="11"
                                       Foreground="{DynamicResource ThirdlyTextBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ManagementUrl}" FontSize="11"
                                       Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" ToolTip="{Binding ManagementUrl}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="探针 URL" FontSize="11"
                                       Foreground="{DynamicResource ThirdlyTextBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ProbeUrl}" FontSize="11"
                                       Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="配置目录" FontSize="11"
                                       Foreground="{DynamicResource ThirdlyTextBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ConfigDirectory}" FontSize="11"
                                       Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" ToolTip="{Binding ConfigDirectory}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="日志目录" FontSize="11"
                                       Foreground="{DynamicResource ThirdlyTextBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LogDirectory}" FontSize="11"
                                       Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" ToolTip="{Binding LogDirectory}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="认证目录" FontSize="11"
                                       Foreground="{DynamicResource ThirdlyTextBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding AuthDirectory}" FontSize="11"
                                       Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" ToolTip="{Binding AuthDirectory}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Options -->
                <Border Grid.Column="2" Background="{DynamicResource SecondaryRegionBrush}"
                        CornerRadius="8" Padding="20">
                    <StackPanel>
                        <TextBlock Text="启动器选项" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,0,0,10"/>
                        <CheckBox Content="关闭时最小化到托盘"
                                  IsChecked="{Binding MinimizeToTrayOnClose}" FontSize="12" Margin="0,0,0,6"/>
                        <CheckBox Content="启动器打开时自动拉起服务"
                                  IsChecked="{Binding AutoStartService}" FontSize="12" Margin="0,0,0,6"/>
                        <CheckBox Content="Windows 登录时自动启动启动器"
                                  IsChecked="{Binding LaunchOnWindowsStartup}" FontSize="12" Margin="0,0,0,6"/>
                        <CheckBox Content="服务启动后自动打开管理页"
                                  IsChecked="{Binding OpenManagementPageAfterStart}" FontSize="12" Margin="0,0,0,6"/>
                        <CheckBox Content="启动时自动检查 CPA 更新"
                                  IsChecked="{Binding CheckForUpdatesOnStartup}" FontSize="12" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="自动拉起延迟" FontSize="12"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <hc:NumericUpDown Value="{Binding AutoStartDelaySeconds}"
                                              Minimum="0" Maximum="600"
                                              Width="72" Height="28"/>
                            <TextBlock Text="秒" FontSize="12"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ============ Row 4: Diagnostics ============ -->
            <Border Grid.Row="4" Background="{DynamicResource SecondaryRegionBrush}"
                    CornerRadius="8" Padding="20">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <TextBlock Text="诊断输出" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="复制" Command="{Binding CopyLogsCommand}"
                                    Width="56" Height="26" FontSize="11" Margin="0,0,6,0"/>
                            <Button Content="导出" Command="{Binding ExportLogsCommand}"
                                    Width="56" Height="26" FontSize="11" Margin="0,0,6,0"/>
                            <Button Content="清空" Command="{Binding ClearLogsCommand}"
                                    Width="56" Height="26" FontSize="11"/>
                        </StackPanel>
                    </DockPanel>

                    <Border Background="{DynamicResource RegionBrush}"
                            CornerRadius="4" Padding="4">
                        <ListBox x:Name="DiagnosticListBox"
                                 ItemsSource="{Binding DiagnosticLines}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 VirtualizingPanel.ScrollUnit="Pixel">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="6,1"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="Focusable" Value="False"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter Margin="{TemplateBinding Padding}"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               FontFamily="Cascadia Mono, Consolas"
                                               FontSize="11"
                                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </DockPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</hc:Window>
