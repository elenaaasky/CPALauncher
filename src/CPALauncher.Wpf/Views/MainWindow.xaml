<hc:Window x:Class="CPALauncher.Views.MainWindow"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:hc="https://handyorg.github.io/handycontrol"
           xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
           xmlns:vm="clr-namespace:CPALauncher.ViewModels"
           Title="CPALauncher"
           Width="1180" Height="860"
           MinWidth="1040" MinHeight="760"
           WindowStartupLocation="CenterScreen"
           WindowStyle="None"
           ResizeMode="CanResizeWithGrip"
           AllowsTransparency="True"
           UseLayoutRounding="True"
           SnapsToDevicePixels="True"
           Background="Transparent"
           BorderBrush="{DynamicResource WindowEdgeBrush}"
           BorderThickness="1"
           AllowDrop="True"
           DragEnter="OnDragEnter"
           DragOver="OnDragOver"
           DragLeave="OnDragLeave"
           Drop="OnDrop">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="8"
                            GlassFrameThickness="0"
                            CornerRadius="10"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <hc:Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <SolidColorBrush x:Key="InkBrush" Color="#142233"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#536376"/>
        <SolidColorBrush x:Key="SoftMutedBrush" Color="#708092"/>
        <SolidColorBrush x:Key="LineBrush" Color="#D9E2EC"/>
        <SolidColorBrush x:Key="CardBrush" Color="#EEF4FA"/>
        <SolidColorBrush x:Key="CardStrongBrush" Color="#F6FAFE"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#EAF1F8"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#44A36E"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#DD8A1F"/>
        <SolidColorBrush x:Key="WindowEdgeBrush" Color="#E8F0F8"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#F7FBFF"/>
        <SolidColorBrush x:Key="ActionBrush" Color="#F8FBFE"/>
        <SolidColorBrush x:Key="ActionHoverBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ActionPressedBrush" Color="#EDF4FA"/>
        <SolidColorBrush x:Key="ChromeHoverBrush" Color="#DDE7F0"/>
        <SolidColorBrush x:Key="ChromePressedBrush" Color="#CEDCE8"/>
        <SolidColorBrush x:Key="SwitchTrackBrush" Color="#CBD5DF"/>
        <SolidColorBrush x:Key="SwitchThumbBrush" Color="#F8FBFE"/>
        <SolidColorBrush x:Key="SwitchCheckedBrush" Color="#59A778"/>
        <SolidColorBrush x:Key="StatusHaloBrush" Color="#CFEADF"/>
        <SolidColorBrush x:Key="DecorativeStrokeBrush" Color="#D9E3EE"/>
        <SolidColorBrush x:Key="DecorativeStrokeAltBrush" Color="#E2EAF2"/>
        <SolidColorBrush x:Key="VersionCardBrush" Color="#F7FBFE"/>
        <SolidColorBrush x:Key="WarningCardBrush" Color="#F3EADF"/>
        <SolidColorBrush x:Key="WarningTextBrush" Color="#8C530F"/>
        <SolidColorBrush x:Key="WarningStrongTextBrush" Color="#9A4D08"/>
        <SolidColorBrush x:Key="OverlayPanelBrush" Color="#F8FBFE"/>
        <SolidColorBrush x:Key="DropOverlayScrimBrush" Color="#660D1722"/>

        <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F7FAFD" Offset="0"/>
            <GradientStop Color="#E8F0F8" Offset="0.62"/>
            <GradientStop Color="#F4F8FC" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="LogoBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#745EEA" Offset="0"/>
            <GradientStop Color="#26A8E7" Offset="0.46"/>
            <GradientStop Color="#55BD71" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PrimaryButtonBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#57B77C" Offset="0"/>
            <GradientStop Color="#349866" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="UpdateButtonBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F3AD36" Offset="0"/>
            <GradientStop Color="#D98422" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="GlassCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.12" Color="#31516C"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ChromeHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ChromePressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ChromeHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryActionStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="MinWidth" Value="108"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="{StaticResource PrimaryButtonBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.93"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.2" Color="#24774F"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SoftActionStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="MinWidth" Value="104"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="{DynamicResource ActionBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ActionHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.1" Color="#31516C"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="UpdateActionStyle" TargetType="Button" BasedOn="{StaticResource PrimaryActionStyle}">
            <Setter Property="Background" Value="{StaticResource UpdateButtonBrush}"/>
            <Setter Property="MinWidth" Value="168"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.18" Color="#B86510"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FlatTextButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ChromeHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="UtilityActionStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="170"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="{DynamicResource ActionBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ActionHoverBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ActionPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.48"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.07" Color="#31516C"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OptionSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Background" Value="{DynamicResource SwitchTrackBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <Ellipse x:Name="Thumb"
                                     Width="18"
                                     Height="18"
                                     Fill="{DynamicResource SwitchThumbBrush}"
                                     HorizontalAlignment="Left"
                                     Margin="3,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource SwitchCheckedBrush}"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RowLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="RowValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="CompactOutlineButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="44"/>
            <Setter Property="Padding" Value="9,0"/>
            <Setter Property="Background" Value="{DynamicResource ActionBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ActionHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ActionPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ConfigTileStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ActionBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>

        <Style x:Key="ConfigSummaryStyle" TargetType="Border" BasedOn="{StaticResource ConfigTileStyle}">
            <Setter Property="Padding" Value="12,8"/>
        </Style>

        <Style x:Key="ConfigTileTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="ConfigTileValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="ConfigBadgeStyle" TargetType="Border">
            <Setter Property="Height" Value="22"/>
            <Setter Property="MinWidth" Value="48"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Background" Value="{DynamicResource StatusHaloBrush}"/>
            <Setter Property="CornerRadius" Value="11"/>
        </Style>

        <Style x:Key="CompactOptionLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

    </hc:Window.Resources>

    <hc:Window.DataContext>
        <vm:MainViewModel/>
    </hc:Window.DataContext>

    <Border Background="{DynamicResource WindowBackgroundBrush}"
            BorderBrush="{DynamicResource WindowEdgeBrush}"
            BorderThickness="1"
            CornerRadius="10">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="62"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="38"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Margin="22,0,20,0"
                  Background="Transparent"
                  MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Image Width="30"
                           Height="30"
                           Source="pack://application:,,,/Assets/app.ico"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           VerticalAlignment="Center"/>
                    <TextBlock Text="CPALauncher"
                               FontSize="19"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource InkBrush}"
                               Margin="12,1,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="&#xE921;"
                            Style="{StaticResource TitleButtonStyle}"
                            Click="OnMinimizeClick"
                            ToolTip="最小化"/>
                    <Button Content="&#xE922;"
                            Style="{StaticResource TitleButtonStyle}"
                            Click="OnMaximizeRestoreClick"
                            ToolTip="最大化"/>
                    <Button Content="&#xE8BB;"
                            Style="{StaticResource TitleButtonStyle}"
                            Click="OnCloseClick"
                            ToolTip="关闭"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="34,18,34,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="188"/>
                    <RowDefinition Height="68"/>
                    <RowDefinition Height="340"/>
                    <RowDefinition Height="*" MinHeight="132"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0"
                        Grid.Column="0"
                        Style="{StaticResource GlassCardStyle}"
                        ClipToBounds="True">
                    <Grid Margin="24,26">
                        <Ellipse Width="260"
                                 Height="260"
                                 Stroke="{DynamicResource DecorativeStrokeBrush}"
                                 StrokeThickness="1"
                                 Opacity="0.55"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Center"
                                 Margin="0,-80,-82,0"/>
                        <Ellipse Width="380"
                                 Height="220"
                                 Stroke="{DynamicResource DecorativeStrokeAltBrush}"
                                 StrokeThickness="1"
                                 Opacity="0.6"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Center"
                                 Margin="0,18,-110,0"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0"
                                  Width="82"
                                  Height="82"
                                  VerticalAlignment="Center">
                                <Ellipse Fill="{DynamicResource StatusHaloBrush}"/>
                                <Ellipse Width="58"
                                         Height="58"
                                         Fill="{Binding StatusForegroundBrush}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="18" ShadowDepth="6" Opacity="0.25" Color="#227548"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <TextBlock Text="{Binding StatusGlyph}"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="28"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <Grid Grid.Column="1"
                                  VerticalAlignment="Center"
                                  Margin="22,0,18,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="{Binding StatusText}"
                                           FontSize="30"
                                           FontWeight="Bold"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{Binding StatusForegroundBrush}"/>
                                <Grid Grid.Row="1" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Width="9"
                                             Height="9"
                                             Fill="{Binding StatusForegroundBrush}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding StatusDetail}"
                                               FontSize="14"
                                               Foreground="{DynamicResource MutedBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding StatusDetail}"/>
                                </Grid>
                            </Grid>

                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Button Command="{Binding StartCommand}"
                                        Style="{StaticResource PrimaryActionStyle}"
                                        Width="116"
                                        Margin="0,0,10,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="15" Margin="0,1,10,0"/>
                                        <TextBlock Text="启动"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding StopCommand}"
                                        Style="{StaticResource SoftActionStyle}"
                                        Width="108"
                                        Margin="0,0,10,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,2,10,0"/>
                                        <TextBlock Text="停止"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding OpenManagementCommand}"
                                        Width="148"
                                        Style="{StaticResource SoftActionStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="15" Margin="0,1,10,0"/>
                                        <TextBlock Text="打开管理页"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Grid.Column="0"
                        Style="{StaticResource GlassCardStyle}"
                        Padding="8"
                        Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Command="{Binding RefreshCommand}" Style="{StaticResource UtilityActionStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="17" Margin="0,0,10,0"/>
                                <TextBlock Text="重新检测"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" Command="{Binding OpenLogsCommand}" Style="{StaticResource UtilityActionStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="17" Margin="0,0,10,0"/>
                                <TextBlock Text="打开日志目录"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

