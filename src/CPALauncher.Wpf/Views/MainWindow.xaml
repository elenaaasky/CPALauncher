                                                    Command="{Binding BrowseConfigCommand}"
                                                    Style="{StaticResource CompactOutlineButtonStyle}"
                                                    VerticalAlignment="Center"/>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="2" Style="{StaticResource ConfigSummaryStyle}">
                                    <Grid>
