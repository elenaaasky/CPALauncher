                                                       ToolTip="{Binding AuthDirectoryToolTip}"
                                                       Style="{StaticResource ConfigTileValueStyle}"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
