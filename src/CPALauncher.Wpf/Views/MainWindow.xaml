<hc:Window x:Class="CPALauncher.Views.MainWindow"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:hc="https://handyorg.github.io/handycontrol"
           xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
           xmlns:vm="clr-namespace:CPALauncher.ViewModels"
           Title="CPALauncher"
           Width="1180" Height="860"
           MinWidth="1040" MinHeight="760"
           WindowStartupLocation="CenterScreen"
           WindowStyle="None"
           ResizeMode="CanResizeWithGrip"
           AllowsTransparency="True"
           UseLayoutRounding="True"
           SnapsToDevicePixels="True"
           Background="Transparent"
           AllowDrop="True"
           DragEnter="OnDragEnter"
           DragOver="OnDragOver"
           DragLeave="OnDragLeave"
           Drop="OnDrop">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="8"
                            GlassFrameThickness="0"
                            CornerRadius="10"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <hc:Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <SolidColorBrush x:Key="InkBrush" Color="#142233"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#536376"/>
        <SolidColorBrush x:Key="SoftMutedBrush" Color="#708092"/>
        <SolidColorBrush x:Key="LineBrush" Color="#D9E2EC"/>
        <SolidColorBrush x:Key="CardBrush" Color="#EEF4FA"/>
        <SolidColorBrush x:Key="CardStrongBrush" Color="#F6FAFE"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#EAF1F8"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#44A36E"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#DD8A1F"/>
        <SolidColorBrush x:Key="WindowEdgeBrush" Color="#E8F0F8"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#F7FBFF"/>
        <SolidColorBrush x:Key="ActionBrush" Color="#F8FBFE"/>
        <SolidColorBrush x:Key="ActionHoverBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ActionPressedBrush" Color="#EDF4FA"/>
        <SolidColorBrush x:Key="ChromeHoverBrush" Color="#DDE7F0"/>
        <SolidColorBrush x:Key="ChromePressedBrush" Color="#CEDCE8"/>
        <SolidColorBrush x:Key="SwitchTrackBrush" Color="#CBD5DF"/>
        <SolidColorBrush x:Key="SwitchThumbBrush" Color="#F8FBFE"/>
        <SolidColorBrush x:Key="SwitchCheckedBrush" Color="#59A778"/>
        <SolidColorBrush x:Key="StatusHaloBrush" Color="#CFEADF"/>
        <SolidColorBrush x:Key="DecorativeStrokeBrush" Color="#D9E3EE"/>
        <SolidColorBrush x:Key="DecorativeStrokeAltBrush" Color="#E2EAF2"/>
        <SolidColorBrush x:Key="VersionCardBrush" Color="#F7FBFE"/>
        <SolidColorBrush x:Key="WarningCardBrush" Color="#F3EADF"/>
        <SolidColorBrush x:Key="WarningTextBrush" Color="#8C530F"/>
        <SolidColorBrush x:Key="WarningStrongTextBrush" Color="#9A4D08"/>
        <SolidColorBrush x:Key="OverlayPanelBrush" Color="#F8FBFE"/>
        <SolidColorBrush x:Key="DropOverlayScrimBrush" Color="#660D1722"/>

        <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F7FAFD" Offset="0"/>
            <GradientStop Color="#E8F0F8" Offset="0.62"/>
            <GradientStop Color="#F4F8FC" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="LogoBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#745EEA" Offset="0"/>
            <GradientStop Color="#26A8E7" Offset="0.46"/>
            <GradientStop Color="#55BD71" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PrimaryButtonBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#57B77C" Offset="0"/>
            <GradientStop Color="#349866" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="UpdateButtonBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F3AD36" Offset="0"/>
            <GradientStop Color="#D98422" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="GlassCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.12" Color="#31516C"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ChromeHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ChromePressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ChromeHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryActionStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="MinWidth" Value="108"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="{StaticResource PrimaryButtonBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.93"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.2" Color="#24774F"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SoftActionStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="MinWidth" Value="104"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="{DynamicResource ActionBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ActionHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.1" Color="#31516C"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="UpdateActionStyle" TargetType="Button" BasedOn="{StaticResource PrimaryActionStyle}">
            <Setter Property="Background" Value="{StaticResource UpdateButtonBrush}"/>
            <Setter Property="MinWidth" Value="168"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.18" Color="#B86510"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FlatTextButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ChromeHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="UtilityActionStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="170"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="{DynamicResource ActionBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ActionHoverBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ActionPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.48"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.07" Color="#31516C"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OptionSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Background" Value="{DynamicResource SwitchTrackBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <Ellipse x:Name="Thumb"
                                     Width="18"
                                     Height="18"
                                     Fill="{DynamicResource SwitchThumbBrush}"
                                     HorizontalAlignment="Left"
                                     Margin="3,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource SwitchCheckedBrush}"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RowLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="RowValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

    </hc:Window.Resources>

    <hc:Window.DataContext>
        <vm:MainViewModel/>
    </hc:Window.DataContext>

    <Border Background="{DynamicResource WindowBackgroundBrush}"
            BorderBrush="{DynamicResource WindowEdgeBrush}"
            BorderThickness="1"
            CornerRadius="10">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="62"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="38"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Margin="22,0,20,0"
                  Background="Transparent"
                  MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="C"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="{StaticResource LogoBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="CPALauncher"
                               FontSize="19"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource InkBrush}"
                               Margin="12,1,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="&#xE921;"
                            Style="{StaticResource TitleButtonStyle}"
                            Click="OnMinimizeClick"
                            ToolTip="最小化"/>
                    <Button Content="&#xE922;"
                            Style="{StaticResource TitleButtonStyle}"
                            Click="OnMaximizeRestoreClick"
                            ToolTip="最大化"/>
                    <Button Content="&#xE8BB;"
                            Style="{StaticResource TitleButtonStyle}"
                            Click="OnCloseClick"
                            ToolTip="关闭"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="34,18,34,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="188"/>
                    <RowDefinition Height="68"/>
                    <RowDefinition Height="300"/>
                    <RowDefinition Height="*" MinHeight="160"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0"
                        Grid.Column="0"
                        Style="{StaticResource GlassCardStyle}"
                        ClipToBounds="True">
                    <Grid Margin="24,26">
                        <Ellipse Width="260"
                                 Height="260"
                                 Stroke="{DynamicResource DecorativeStrokeBrush}"
                                 StrokeThickness="1"
                                 Opacity="0.55"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Center"
                                 Margin="0,-80,-82,0"/>
                        <Ellipse Width="380"
                                 Height="220"
                                 Stroke="{DynamicResource DecorativeStrokeAltBrush}"
                                 StrokeThickness="1"
                                 Opacity="0.6"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Center"
                                 Margin="0,18,-110,0"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0"
                                  Width="82"
                                  Height="82"
                                  VerticalAlignment="Center">
                                <Ellipse Fill="{DynamicResource StatusHaloBrush}"/>
                                <Ellipse Width="58"
                                         Height="58"
                                         Fill="{Binding StatusForegroundBrush}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="18" ShadowDepth="6" Opacity="0.25" Color="#227548"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <TextBlock Text="{Binding StatusGlyph}"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="28"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <Grid Grid.Column="1"
                                  VerticalAlignment="Center"
                                  Margin="22,0,18,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="{Binding StatusText}"
                                           FontSize="30"
                                           FontWeight="Bold"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{Binding StatusForegroundBrush}"/>
                                <Grid Grid.Row="1" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Width="9"
                                             Height="9"
                                             Fill="{Binding StatusForegroundBrush}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding StatusDetail}"
                                               FontSize="14"
                                               Foreground="{DynamicResource MutedBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding StatusDetail}"/>
                                </Grid>
                            </Grid>

                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Button Command="{Binding StartCommand}"
                                        Style="{StaticResource PrimaryActionStyle}"
                                        Width="116"
                                        Margin="0,0,10,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="15" Margin="0,1,10,0"/>
                                        <TextBlock Text="启动"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding StopCommand}"
                                        Style="{StaticResource SoftActionStyle}"
                                        Width="108"
                                        Margin="0,0,10,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,2,10,0"/>
                                        <TextBlock Text="停止"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding OpenManagementCommand}"
                                        Width="148"
                                        Style="{StaticResource SoftActionStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="15" Margin="0,1,10,0"/>
                                        <TextBlock Text="打开管理页"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Grid.Column="0"
                        Style="{StaticResource GlassCardStyle}"
                        Padding="8"
                        Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Command="{Binding RefreshCommand}" Style="{StaticResource UtilityActionStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="17" Margin="0,0,10,0"/>
                                <TextBlock Text="重新检测"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" Command="{Binding OpenLogsCommand}" Style="{StaticResource UtilityActionStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="17" Margin="0,0,10,0"/>
                                <TextBlock Text="打开日志目录"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="0"
                        Grid.RowSpan="2"
                        Grid.Column="2"
                        Style="{StaticResource GlassCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="44"/>
                        </Grid.RowDefinitions>

                        <StackPanel Margin="18,16,18,10">
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="版本"
                                           Foreground="{DynamicResource InkBrush}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Button Command="{Binding CheckAllUpdatesCommand}"
                                        Style="{StaticResource FlatTextButtonStyle}"
                                        BorderBrush="{DynamicResource LineBrush}"
                                        BorderThickness="1"
                                        Height="30"
                                        MinWidth="92"
                                        HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0"/>
                                        <TextBlock Text="检查全部"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Border Background="{DynamicResource VersionCardBrush}" CornerRadius="9" Padding="12,8" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                                            <TextBlock Text="CPALauncher"
                                                       Foreground="{DynamicResource InkBrush}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding LauncherCurrentVersionDisplay}"
                                                       Foreground="{DynamicResource InkBrush}"
                                                       FontSize="14"
                                                       Margin="10,0,0,0"/>
                                        </StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Width="8" Height="8" Fill="{Binding LauncherUpdateStateBrush}" VerticalAlignment="Center" Margin="0,0,9,0"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding LauncherUpdateCardText}"
                                                       Foreground="{Binding LauncherUpdateStateBrush}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                        <ProgressBar Value="{Binding LauncherUpdateProgress}"
                                                     Maximum="100"
                                                     Height="16"
                                                     FontSize="10"
                                                     Margin="0,8,0,0"
                                                     Visibility="{Binding LauncherUpdateProgressVisibility}"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Command="{Binding CheckLauncherUpdateCommand}"
                                            Style="{StaticResource FlatTextButtonStyle}"
                                            BorderBrush="{DynamicResource LineBrush}"
                                            BorderThickness="1"
                                            Height="30"
                                            Width="32"
                                            MinWidth="32"
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center"
                                            ToolTip="{Binding LauncherUpdateActionText}">
                                        <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                    </Button>
                                </Grid>
                            </Border>

                            <Border Background="{DynamicResource WarningCardBrush}" CornerRadius="9" Padding="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                                            <TextBlock Text="CPA"
                                                       Foreground="{DynamicResource InkBrush}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding CurrentCpaVersionDisplay}"
                                                       Foreground="{DynamicResource InkBrush}"
                                                       FontSize="14"
                                                       Margin="10,0,0,0"/>
                                        </StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Width="8" Height="8" Fill="{Binding UpdateStateBrush}" VerticalAlignment="Center" Margin="0,0,9,0"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding UpdateCardText}"
                                                       Foreground="{Binding UpdateStateBrush}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                        <ProgressBar Value="{Binding UpdateProgress}"
                                                     Maximum="100"
                                                     Height="16"
                                                     FontSize="10"
                                                     Margin="0,8,0,0"
                                                     Visibility="{Binding UpdateProgressVisibility}"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Command="{Binding CheckForUpdateCommand}"
                                            Style="{StaticResource FlatTextButtonStyle}"
                                            BorderBrush="{DynamicResource LineBrush}"
                                            BorderThickness="1"
                                            Height="30"
                                            Width="32"
                                            MinWidth="32"
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center"
                                            ToolTip="{Binding UpdateActionText}">
                                        <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <Border Grid.Row="1"
                                BorderBrush="{DynamicResource LineBrush}"
                                BorderThickness="0,1,0,0">
                            <UniformGrid Columns="2" Margin="12,0">
                                <Button Command="{Binding OpenRepositoryCommand}"
                                        Style="{StaticResource FlatTextButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE734;" FontFamily="Segoe MDL2 Assets" FontSize="15" Margin="0,0,8,0"/>
                                        <TextBlock Text="项目仓库"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding OpenCpaRepositoryCommand}"
                                        Style="{StaticResource FlatTextButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0"/>
                                        <TextBlock Text="CPA 源项目"/>
                                    </StackPanel>
                                </Button>
                            </UniformGrid>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="2"
                      Grid.Column="0"
                      Grid.ColumnSpan="3"
                      Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.28*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource GlassCardStyle}"
                            Padding="16,14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="配置"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource InkBrush}"
                                       Margin="0,0,0,8"/>

                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="28"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0"/>
                                        <ColumnDefinition Width="125"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="17" Foreground="{DynamicResource InkBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="可执行文件" Style="{StaticResource RowLabelStyle}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding ExecutablePath}" ToolTip="{Binding ExecutablePath}" Style="{StaticResource RowValueStyle}"/>
                                    <Button Grid.Column="3" Content="浏览" Command="{Binding BrowseExecutableCommand}" Style="{StaticResource FlatTextButtonStyle}"/>
                                    <Button Grid.Column="4" Content="&#xE76C;" Command="{Binding OpenExecutableDirCommand}" Style="{StaticResource FlatTextButtonStyle}" FontFamily="Segoe MDL2 Assets"/>
                                </Grid>
                                <Border Grid.Row="0" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1"/>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0"/>
                                        <ColumnDefinition Width="125"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="17" Foreground="{DynamicResource InkBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="配置文件" Style="{StaticResource RowLabelStyle}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding ConfigPath}" ToolTip="{Binding ConfigPath}" Style="{StaticResource RowValueStyle}"/>
                                    <Button Grid.Column="3" Content="浏览" Command="{Binding BrowseConfigCommand}" Style="{StaticResource FlatTextButtonStyle}"/>
                                    <Button Grid.Column="4" Content="&#xE76C;" Command="{Binding OpenConfigDirCommand}" Style="{StaticResource FlatTextButtonStyle}" FontFamily="Segoe MDL2 Assets"/>
                                </Grid>
                                <Border Grid.Row="1" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1"/>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0"/>
                                        <ColumnDefinition Width="125"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="{DynamicResource InkBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="管理页 URL" Style="{StaticResource RowLabelStyle}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding ManagementUrl}" ToolTip="{Binding ManagementUrl}" Style="{StaticResource RowValueStyle}"/>
                                    <Button Grid.Column="3" Content="&#xE8A7;" Command="{Binding OpenManagementCommand}" Style="{StaticResource FlatTextButtonStyle}" FontFamily="Segoe MDL2 Assets"/>
                                </Grid>
                                <Border Grid.Row="2" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1"/>

                                <Grid Grid.Row="3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0"/>
                                        <ColumnDefinition Width="125"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE968;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="{DynamicResource InkBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="探针 URL" Style="{StaticResource RowLabelStyle}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding ProbeUrl}" ToolTip="{Binding ProbeUrl}" Style="{StaticResource RowValueStyle}"/>
                                </Grid>
                                <Border Grid.Row="3" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1"/>

                                <Grid Grid.Row="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0"/>
                                        <ColumnDefinition Width="125"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="{DynamicResource InkBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="配置目录" Style="{StaticResource RowLabelStyle}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding ConfigDirectory}" ToolTip="{Binding ConfigDirectory}" Style="{StaticResource RowValueStyle}"/>
                                    <Button Grid.Column="3" Content="&#xE76C;" Command="{Binding OpenConfigDirCommand}" Style="{StaticResource FlatTextButtonStyle}" FontFamily="Segoe MDL2 Assets"/>
                                </Grid>
                                <Border Grid.Row="4" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1"/>

                                <Grid Grid.Row="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0"/>
                                        <ColumnDefinition Width="125"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="{DynamicResource InkBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="日志目录" Style="{StaticResource RowLabelStyle}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding LogDirectory}" ToolTip="{Binding LogDirectory}" Style="{StaticResource RowValueStyle}"/>
                                    <Button Grid.Column="3" Content="&#xE76C;" Command="{Binding OpenLogsCommand}" Style="{StaticResource FlatTextButtonStyle}" FontFamily="Segoe MDL2 Assets"/>
                                </Grid>
                                <Border Grid.Row="5" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1"/>

                                <Grid Grid.Row="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0"/>
                                        <ColumnDefinition Width="125"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="17" Foreground="{DynamicResource InkBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="认证目录" Style="{StaticResource RowLabelStyle}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding AuthDirectory}" ToolTip="{Binding AuthDirectory}" Style="{StaticResource RowValueStyle}"/>
                                </Grid>
                                <Border Grid.Row="6" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1"/>

                                <Grid Grid.Row="7">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0"/>
                                        <ColumnDefinition Width="125"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="64"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="17" Foreground="{DynamicResource InkBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="管理密钥" Style="{StaticResource RowLabelStyle}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding ManagementSecretKeyDisplay}" ToolTip="{Binding ManagementSecretKeyToolTip}" Style="{StaticResource RowValueStyle}"/>
                                    <Button Grid.Column="3" Content="复制" Command="{Binding CopyManagementSecretKeyCommand}" Style="{StaticResource FlatTextButtonStyle}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1"/>
                                    <TextBlock Grid.Column="4" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource GlassCardStyle}"
                            Padding="16,14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="启动器选项"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource InkBrush}"
                                       Margin="0,0,0,8"/>

                            <Border Grid.Row="1"
                                    BorderBrush="{DynamicResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="30"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="14,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="0"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="19" Foreground="{DynamicResource InkBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="开机启动" Style="{StaticResource RowLabelStyle}"/>
                                        <ToggleButton Grid.Column="2" Style="{StaticResource OptionSwitchStyle}" IsChecked="{Binding LaunchOnWindowsStartup}"/>
                                    </Grid>
                                    <Border Grid.Row="0" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1"/>

                                    <Grid Grid.Row="1" Margin="14,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="0"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#xE81A;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource InkBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="关闭到托盘" Style="{StaticResource RowLabelStyle}"/>
                                        <ToggleButton Grid.Column="2" Style="{StaticResource OptionSwitchStyle}" IsChecked="{Binding MinimizeToTrayOnClose}"/>
                                    </Grid>
                                    <Border Grid.Row="1" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1"/>

                                    <Grid Grid.Row="2" Margin="14,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="0"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource InkBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="启动后打开管理页" Style="{StaticResource RowLabelStyle}"/>
                                        <ToggleButton Grid.Column="2" Style="{StaticResource OptionSwitchStyle}" IsChecked="{Binding OpenManagementPageAfterStart}"/>
                                    </Grid>
                                    <Border Grid.Row="2" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1"/>

                                    <Grid Grid.Row="3" Margin="14,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="0"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource InkBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="启动时检查更新" Style="{StaticResource RowLabelStyle}"/>
                                        <ToggleButton Grid.Column="2" Style="{StaticResource OptionSwitchStyle}" IsChecked="{Binding CheckForUpdatesOnStartup}"/>
                                    </Grid>
                                    <Border Grid.Row="3" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1"/>

                                    <Grid Grid.Row="4" Margin="14,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="0"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="17" Foreground="{DynamicResource InkBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="打开时自动拉起服务" Style="{StaticResource RowLabelStyle}"/>
                                        <ToggleButton Grid.Column="2" Style="{StaticResource OptionSwitchStyle}" IsChecked="{Binding AutoStartService}"/>
                                    </Grid>
                                    <Border Grid.Row="4" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1"/>

                                    <Grid Grid.Row="5" Margin="14,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="0"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#xE916;" FontFamily="Segoe MDL2 Assets" FontSize="17" Foreground="{DynamicResource InkBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="自动拉起延迟" Style="{StaticResource RowLabelStyle}"/>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <hc:NumericUpDown Value="{Binding AutoStartDelaySeconds}"
                                                              Minimum="0"
                                                              Maximum="600"
                                                              Width="68"
                                                              Height="25"
                                                              Padding="8,2"
                                                              Background="{DynamicResource ActionBrush}"
                                                              BorderBrush="{DynamicResource LineBrush}"
                                                              BorderThickness="1"
                                                              Foreground="{DynamicResource InkBrush}"
                                                              FontSize="13"
                                                              hc:BorderElement.CornerRadius="7"/>
                                            <TextBlock Text="秒" FontSize="12" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                    <Border Grid.Row="5" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1"/>

                                    <Grid Grid.Row="6" Margin="14,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="0"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#xE708;" FontFamily="Segoe MDL2 Assets" FontSize="17" Foreground="{DynamicResource InkBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="深色模式" Style="{StaticResource RowLabelStyle}"/>
                                        <ToggleButton Grid.Column="2" Style="{StaticResource OptionSwitchStyle}" IsChecked="{Binding IsDarkMode}"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="3"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Style="{StaticResource GlassCardStyle}"
                        Padding="18,14"
                        Margin="0,14,0,0">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                            <TextBlock Text="诊断输出"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource InkBrush}"
                                       VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Command="{Binding CopyLogsCommand}" Style="{StaticResource FlatTextButtonStyle}" Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="15" Margin="0,0,6,0"/>
                                        <TextBlock Text="复制日志"/>
                                    </StackPanel>
                                </Button>
                                <Border Width="1" Background="{DynamicResource LineBrush}" Margin="0,6,8,6"/>
                                <Button Command="{Binding ExportLogsCommand}" Style="{StaticResource FlatTextButtonStyle}" Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="15" Margin="0,0,6,0"/>
                                        <TextBlock Text="导出日志"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding ClearLogsCommand}" Style="{StaticResource FlatTextButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="15" Margin="0,0,6,0"/>
                                        <TextBlock Text="清空"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <Border BorderBrush="{DynamicResource LineBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="0,4,0,0">
                            <ListBox x:Name="DiagnosticListBox"
                                     ItemsSource="{Binding DiagnosticLines}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Visible"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling"
                                     VirtualizingPanel.ScrollUnit="Pixel">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="2,4"/>
                                        <Setter Property="Focusable" Value="False"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1">
                                                        <ContentPresenter Margin="{TemplateBinding Padding}"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   FontFamily="Cascadia Mono, Consolas"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource MutedBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </DockPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="2" Margin="34,0,34,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8"
                             Height="8"
                             Fill="{Binding StatusForegroundBrush}"
                             Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding FooterStatusText}"
                               FontSize="13"
                               Foreground="{DynamicResource MutedBrush}"/>
                </StackPanel>
            </Grid>

            <Border HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,76,34,0"
                    Padding="16,12"
                    CornerRadius="10"
                    Background="{DynamicResource OverlayPanelBrush}"
                    BorderBrush="{DynamicResource LineBrush}"
                    BorderThickness="1"
                    Opacity="0.98"
                    Panel.ZIndex="20"
                    IsHitTestVisible="False"
                    Visibility="{Binding IsImportNoticeVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.18"/>
                </Border.Effect>
                <TextBlock Text="{Binding ImportNoticeText}"
                           FontSize="13"
                           Foreground="{DynamicResource InkBrush}"
                           TextWrapping="Wrap"
                           MaxWidth="320"/>
            </Border>

            <StackPanel x:Name="MainGrowlPanel"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Width="360"
                        Margin="0,76,34,0"
                        Panel.ZIndex="25"/>

            <Grid Grid.RowSpan="3"
                  Panel.ZIndex="15"
                  Background="{DynamicResource DropOverlayScrimBrush}"
                  IsHitTestVisible="False"
                  Visibility="{Binding IsTokenDropOverlayVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="520"
                        Padding="28,24"
                        CornerRadius="16"
                        Background="{DynamicResource OverlayPanelBrush}"
                        BorderThickness="2"
                        BorderBrush="{Binding TokenDropAccentBrush}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.28"/>
                    </Border.Effect>
                    <StackPanel HorizontalAlignment="Center">
                        <Border Width="58"
                                Height="58"
                                CornerRadius="29"
                                Background="{Binding TokenDropAccentBrush}"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,14">
                            <TextBlock Text="&#xE8B5;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="25"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding TokenDropTitle}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource InkBrush}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding TokenDropSubtitle}"
                                   FontSize="13"
                                   Foreground="{DynamicResource MutedBrush}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="420"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</hc:Window>
