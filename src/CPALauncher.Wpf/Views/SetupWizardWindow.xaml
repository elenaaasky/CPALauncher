<hc:Window x:Class="CPALauncher.Views.SetupWizardWindow"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:hc="https://handyorg.github.io/handycontrol"
           Title="CPA 初始配置向导"
           Width="500" Height="420"
           WindowStartupLocation="CenterOwner"
           ResizeMode="NoResize"
           UseLayoutRounding="True"
           SnapsToDevicePixels="True"
           Background="{DynamicResource RegionBrush}">

    <Grid Margin="28,24,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="配置 CPA 参数"
                       FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryTextBrush}"/>
            <TextBlock Text="CPA 已下载完成，请确认以下参数。默认值适合大多数场景，可直接点击「完成配置」。"
                       FontSize="12" Margin="0,6,0,0"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource SecondaryTextBrush}"/>
        </StackPanel>

        <!-- Form -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="监听地址"
                       FontSize="12" VerticalAlignment="Center"
                       Foreground="{DynamicResource SecondaryTextBrush}"/>
            <TextBox Grid.Row="0" Grid.Column="1"
                     x:Name="HostTextBox" Text="127.0.0.1"
                     FontSize="12"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="监听端口"
                       FontSize="12" VerticalAlignment="Center"
                       Foreground="{DynamicResource SecondaryTextBrush}"/>
            <hc:NumericUpDown Grid.Row="2" Grid.Column="1"
                              x:Name="PortNumericUpDown"
                              Value="8317" Minimum="1" Maximum="65535"
                              Height="28"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="代理地址"
                       FontSize="12" VerticalAlignment="Center"
                       Foreground="{DynamicResource SecondaryTextBrush}"/>
            <TextBox Grid.Row="4" Grid.Column="1"
                     x:Name="ProxyUrlTextBox" Text="http://127.0.0.1:7897"
                     FontSize="12"
                     hc:InfoElement.Placeholder="留空则不使用代理"/>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="管理密钥"
                       FontSize="12" VerticalAlignment="Center"
                       Foreground="{DynamicResource SecondaryTextBrush}"/>
            <PasswordBox Grid.Row="6" Grid.Column="1"
                         x:Name="SecretKeyPasswordBox"
                         FontSize="12"/>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="跳过" Width="80" Height="36"
                    Margin="0,0,12,0"
                    Click="OnSkipClick"/>
            <Button Content="完成配置" Width="100" Height="36"
                    Style="{StaticResource ButtonPrimary}"
                    Click="OnFinishClick"/>
        </StackPanel>
    </Grid>
</hc:Window>
